Bootstrap: docker
From: nvidia/cuda:12.2.0-devel-ubuntu22.04

%files
    requirements.txt requirements.txt

%post
    # default
    apt-get update && apt-get install -y gcc make wget git
    apt install software-properties-common -y
    add-apt-repository ppa:deadsnakes/ppa -y
    apt update
    apt-get install -y python3.10 python3.10-distutils python3-pip

    # Ensure `python` points to python3.10
    update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1
    update-alternatives --set python /usr/bin/python3.10

    # Ensure `pip` points to pip3
    update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1
    update-alternatives --set pip /usr/bin/pip3

    # Verify
    python --version
    pip --version

    # Install Python dependencies
    pip install -r requirements.txt

%labels
    Author Giwon Shin
    ContactEmail gshin22@wisc.edu
    Name Automated Container Template
